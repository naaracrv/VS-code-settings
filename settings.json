    "diffEditor.ignoreTrimWhitespace": false,
    "editor.codeActionsOnSave": { "source.fixAll.eslint": true },
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.python"
    },
    // "[html]": {
    //     "editor.formatOnSave": true,
    //     "editor.defaultFormatter": "vscode.html-language-features"
    // },
    "[html, scss, css, json, javascript, typescript, jsx, markdown, yaml]": { 
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "emmet.syntaxProfiles": {
        "nunjucks": "html",
        "javascript": "jsx"
    },
    "emmet.includeLanguages": {
        "nunjucks": "html",
        "javascript": "javascriptreact"
    },
    "extensions.autoUpdate": true,
    "extensions.ignoreRecommendations": false,
    "explorer.confirmDelete": false,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "files.autoSave": "afterDelay",
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true
        // "**/node_modules": true
    },
    "files.associations": {
        ".sequelizerc": "javascript",
        ".stylelintrc": "json",
        ".prettierrc": "json",
        "*.tsx": "typescriptreact"
    },
    "gitlens.codeLens.enabled": false,
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.recentChange.enabled": false,
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "javascript.suggest.autoImports": true,
    "javascript.updateImportsOnFileMove.enabled": "never",
    "json.maxItemsComputed": 50000,
    "liveshare.featureSet": "insiders",
    "liveServer.settings.donotVerifyTags": true,
    "liveServer.settings.donotShowInfoMsg": true,
    "material-icon-theme.activeIconPack": "nest",
    "material-icon-theme.folders.associations": {
        "grpc": "pipe",
        "infra": "app",
        "fakes": "mock",
        "protos": "pipe",
        "domain": "class",
        "mappers": "meta",
        "kafka": "scripts",
        "schemas": "class",
        "_shared": "shared",
        "entities": "class",
        "http": "container",
        "dtos": "typescript",
        "kube": "kubernetes",
        "websockets": "pipe",
        "typeorm": "database",
        "migrations": "tools",
        "providers": "include",
        "modules": "components",
        "useCases": "controller",
        "eslint-config": "tools",
        "subscribers": "messages",
        "implementations": "core",
        "repositories": "mappings"
    },
    "material-icon-theme.files.associations": {
        "*.proto": "3d",
        "tsconfig.json": "tune",
        "*.webpack.js": "webpack",
        "ormconfig.json": "database"
    },
    "markdown.experimental.editor.pasteLinks.enabled": true,
    "python.defaultInterpreterPath": "C:\\Users\\naara\\AppData\\Local\\Microsoft\\WindowsApps\\python3.10.exe",
    "python.formatting.provider": "yapf",
    "python.linting.pylintEnabled": true,
    "python.linting.enabled": true,
    "python.testing.autoTestDiscoverOnSaveEnabled": false,
    "prettier.tabWidth": 4,
    "screencastMode.onlyKeyboardShortcuts": true,
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.showExitAlert": false,
    "terminal.integrated.cursorStyle": "underline",
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.fontFamily": "'Fira Code'",
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.tabs.enabled": false,
    "typescript.tsserver.log": "verbose",
    "typescript.suggest.autoImports": true,
    "typescript.updateImportsOnFileMove.enabled": "never",
    "window.zoomLevel": -1,
    "window.dialogStyle": "custom",
    "workbench.colorTheme": "Aura Dark",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.startupEditor": "none",
    "workbench.editor.labelFormat": "short",
    "workbench.editor.untitled.hint": "hidden",
    "workbench.colorCustomizations": { "bookmarks.lineBackground": "#157EFB88" },
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook",
        "*.html": "default",
        "*.js": "default",
        "*.docx": "default"
    },
