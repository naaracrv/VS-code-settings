{
    "editor.tabSize": 4,
    "editor.fontSize": 18, // Configura tamanho da fonte
    "editor.lineHeight": 25,
    "editor.fontLigatures": true,
    "editor.mouseWheelZoom": true,
    "editor.columnSelection": false,
    "editor.detectIndentation": true,
    "editor.fontFamily": "'Fira Code'", // Configura família da fonte
    "editor.suggestSelection": "first",
    "editor.renderLineHighlight": "gutter",
    "editor.parameterHints.enabled": false,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "editor.semanticHighlighting.enabled": false,
    "editor.rulers": [ 100, 150, 200 ], // Aplica linhas verticais para lembrar de quebrar linha em códigos muito grandes
    "breadcrumbs.enabled": true,
    "bookmarks.sideBar.expanded": false,
    "bookmarks.saveBookmarksInProject": true,
    "bookmarks.navigateThroughAllFiles": true,
    "bookmarks.showCommandsInContextMenu": true,
    "code-runner.runInTerminal": true,
    "code-runner.ignoreSelection": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.saveAllFilesBeforeRun": true,
    "code-runner.executorMapByFileExtension": { ".vbs": "cscript //Nologo" },
    "code-runner.executorMapByGlob": {
        "*.js": "node",
        "*.test.js": "tap",
        "pom.xml": "cd $dir && mvn clean package"
    },
    "code-runner.executorMap": {
        "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "r": "Rscript",
        "v": "v run",
        "go": "go run",
        "bat": "cmd /c",
        "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "php": "php",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "lua": "lua",
        "ahk": "autohotkey",
        "kit": "kitc --run",
        "sml": "cd $dir && sml $fileName",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        "perl": "perl",
        "dart": "dart",
        "lisp": "sbcl --script",
        "sass": "sass --style expanded",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "scss": "scss --style expanded",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "html": "html",
        "ruby": "ruby",
        "perl6": "perl6",
        "scala": "scala",
        "swift": "swift",
        "ocaml": "ocaml",
        "julia": "julia",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "python": "python -u",
        "groovy": "groovy",
        "csharp": "scriptcs",
        "fsharp": "fsi",
        "racket": "racket",
        "scheme": "csi -script",
        "autoit": "autoit3",
        "haskell": "runhaskell",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "crystal": "crystal",
        "clojure": "lein exec",
        "vbscript": "cscript //Nologo",
        "javascript": "node",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "typescript": "ts-node",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "shellscript": "bash",
        "applescript": "osascript",
        "coffeescript": "coffee",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt"
    },
    "cSpell.language": "en,pt,pt-BR,en-US,en-GB",
    "kite.showWelcomeNotificationOnStartup": false,
